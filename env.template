# No API key needed — Binance L2 depth and trade data are public endpoints.
# Copy this file to .env and just set a real DB password.

DB_PASSWORD=change_me_before_prod
DATABASE_URL=postgresql://orderflow:${DB_PASSWORD}@timescaledb:5432/orderflow
REDIS_URL=redis://redis:6379/0

# Symbols to track — Binance format, uppercase, comma-separated
SYMBOLS=BTCUSDT,ETHUSDT

# Detection engine tuning — starting points, calibrate against real data
THRESHOLD_MULT=6.0
PERSISTENCE_SECONDS=4.0
IMBALANCE_BAND_PCT=0.5
FLOW_WINDOW_SECONDS=10.0
FLOW_SPIKE_MULT=4.0
SWEEP_TOLERANCE_PCT=0.06
DEPTH_LEVELS=20
DEPTH_SPEED_MS=100
